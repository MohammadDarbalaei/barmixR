Package: barmixR
Type: Package
Title: Bayesian Modeling of Barcoded Tumor Mixtures for Quantitative Treatment Resistance Analysis
Version: 0.99.0
Authors@R: 
    c(
      person(given = "Mohammad", family = "Darbalaei",
             email = "mohammad.darbalaei@uni-due.de",
